GEMINI_API_KEY=your_gemini_api_key_here
PORT=5001
NODE_ENV=development
# Optional: CSV path for meal data (if not using inline data)
MEALS_CSV_PATH=./data/meals.csv
SIDES_CSV_PATH=./data/sides.csv
# Push notification VAPID keys (generate with: npx web-push generate-vapid-keys --json)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com
